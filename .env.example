# Server Configuration
NODE_ENV=production
PORT=3000

# Base URL (used for Stripe Checkout redirect URLs)
BASE_URL=https://permit-intelligence-platform.vercel.app

# Stripe Payments (get from dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get webhook secret by creating an endpoint in Stripe Dashboard → Developers → Webhooks
# Event to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# JWT Auth Secret (generate a random 64-char string, e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-64-char-string

# Database (SQLite - file-based on Railway persistent storage)
# Database file will be created at: src/data/app.db

# Admin Email
ADMIN_EMAIL=ashwinramcharan21@gmail.com

# Email Configuration (for reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Google Analytics
GOOGLE_ANALYTICS_ID=G-740YX0W0GE

# PDOK API (optional - uses public endpoint by default)
PDOK_API_KEY=

# i18n Configuration
I18N_DEBUG=false
